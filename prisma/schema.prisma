datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Insumo {
  id               Int      @id @default(autoincrement()) //Mudou aqui!
  nome             String
  descricao        String?
  fabricante       String
  capacidade_total Float
  quantidade_atual Float
  unidade          String
  status           String   @default("DISPONIVEL")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  lotes            Lote[]
}

model Lote {
  id                 Int      @id @default(autoincrement()) //Mudou aqui!
  numero_lote        String
  fabricante         String
  quantidade_inicial Float
  quantidade_atual   Float
  data_validade      DateTime
  createdAt          DateTime @default(now())
  insumoId           Int      //Mudou aqui para número!
  insumo             Insumo   @relation(fields: [insumoId], references: [id])

  @@unique([numero_lote, fabricante], name: "numero_lote_fabricante")
}